# Server-side only. Never expose these values through VITE_* variables.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Gorilla Canvas MCP (legacy HTTP + SSE). Keep the rotated token server-side only.
MCP_SERVER_URL=https://canvas.dxx.cn/api/mcp/sse
MCP_AUTH_TOKEN=
MCP_ASSET_HOSTS=

# Optional overrides
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
OPENAI_IMAGE_MODEL=gpt-image-2
PORT=5173
