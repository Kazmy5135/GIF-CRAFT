# Server-side only. Never expose these values through VITE_* variables.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Gorilla Canvas MCP (legacy HTTP + SSE). Keep the rotated token server-side only.
MCP_SERVER_URL=https://canvas.dxx.cn/api/mcp/sse
MCP_AUTH_TOKEN=
MCP_TEXT_TO_IMAGE_TOOL=
MCP_IMAGE_TO_IMAGE_TOOL=

# Tool argument mapping. Confirm these names against GET /api/mcp/tools.
MCP_PROMPT_FIELD=prompt
MCP_IMAGE_FIELD=image
MCP_IMAGE_FORMAT=data-url
MCP_ASPECT_RATIO_FIELD=
MCP_QUALITY_FIELD=
MCP_COUNT_FIELD=

# Optional overrides
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
OPENAI_IMAGE_MODEL=gpt-image-2
PORT=5173
